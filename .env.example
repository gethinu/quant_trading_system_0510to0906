# Copy this file to .env and fill values

# ===== Market Data (Polygon.io 無料 tier — 本命 $0 full-market) =====
# 日次 OHLCV 取得用。無料 tier で SIP 連結の full-market volume を取得可能。
# Grouped Daily エンドポイントは 1 call/日で全 US 銘柄を返す (5 req/min 制限を回避)。
# API キー取得先 (無料): https://polygon.io/dashboard/signup
POLYGON_API_KEY=

# ===== Market Data (Alpaca 無料 IEX feed) =====
# 日次 OHLCV 取得用。無料 tier = IEX feed のみ (SIP は有料 $99/月)。
# 注意: IEX feed は全市場出来高の ~2-4% しか反映せず min-ADV フィルタが壊滅するため
#       株の日次データ本番運用には非推奨 (Polygon を優先)。発注連携用途では有効。
# API キー取得先: https://app.alpaca.markets/
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
# feed override (既定 iex)。SIP に切り替える場合のみ sip を指定 (有料)。
# ALPACA_FEED=iex

# EODHD API キー (deprecated, retained for legacy scripts)。
# データ取得は Alpaca に移行済。旧 bulk/legacy スクリプト用に残置。
EODHD_API_KEY=

# ===== Alpaca Paper Trading (ブローカー連携) =====
# 発注/ペーパートレード用。データ取得用 ALPACA_API_KEY と同じキーを流用可。
# Get your API keys from https://alpaca.markets/
APCA_API_KEY_ID=
APCA_API_SECRET_KEY=
ALPACA_PAPER=true  # Use paper trading (virtual money)

# === 当日シグナル配信 (scripts/publish_signals.py) ==========================
# setup 手順: docs/HUMAN_TASK_publishers_setup_20260701.md
#
# Primary publisher: ntfy.sh (無料, iPhone push 3 分 setup)
# NTFY_TOPIC は URL path そのものが secret。推測不能な文字列にすること。
NTFY_TOPIC=quant-gethinu-REPLACE_WITH_RANDOM_HEX16
NTFY_URL=https://ntfy.sh
# X-Priority: 3=default, 4=high, 5=urgent (WARN 時は自動で 5)
NTFY_PRIORITY=4
#
# Backup publisher: SendGrid email (無料 tier 100 通/日)
SENDGRID_API_KEY=SG.xxxxx
SENDGRID_FROM_EMAIL=quant-bot@example.com
SENDGRID_TO_EMAIL=gethteiben@gmail.com
# 1 で ntfy 成功時も email を並列送信 (default 0 = fallback のみ)
EMAIL_ALWAYS=0
# ===========================================================================

# === AI narrator (common/narrator.py, scripts/generate_narrative.py) ========
# 当日シグナルを quant analyst 風に 2 段落解説し dashboard / 配信に載せる層。
# 未設定なら fail-safe で空 narrative (pipeline は narrative 無しで継続)。
# API キー取得先: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=
# narrator model (default: claude-haiku-4-5-20251001, 1 回 ~$0.006)
NARRATOR_MODEL=claude-haiku-4-5-20251001
# ===========================================================================

# Optional: Notifications
# Discord incoming webhook URL (legacy: common/notifier.py の coverage warn 用)
DISCORD_WEBHOOK_URL=
# Slack incoming webhook URL (if you use Slack)
SLACK_WEBHOOK_URL=
# Slack Bot token (alternative to webhook)
SLACK_BOT_TOKEN=
# Slack channel name (e.g. #general) or channel ID (e.g. C0123456)
SLACK_CHANNEL=
# Slack channels by event type (optional; overrides SLACK_CHANNEL when set)
# Logs/progress text for backtests
SLACK_CHANNEL_LOGS=
# Equity images and backtest performance
SLACK_CHANNEL_EQUITY=
# Trade signal picks
SLACK_CHANNEL_SIGNALS=
# Microsoft Teams incoming webhook URL (if you use Teams)
TEAMS_WEBHOOK_URL=

# ===== Bulk API Data Quality Settings =====
# Volume tolerance (percentage): default 5.0%
# Allows minor discrepancies in volume data between Bulk API and cache
BULK_API_VOLUME_TOLERANCE=5.0

# Price tolerance (percentage): default 0.5%
# Strict validation for OHLC price data
BULK_API_PRICE_TOLERANCE=0.5

# Minimum reliability score (percentage): default 70.0%
# Bulk API will be used if reliability score >= this threshold
BULK_API_MIN_RELIABILITY=70.0
